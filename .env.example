# Copy to .env and fill in values before running docker compose.
# Never commit .env to source control.

# --- Postgres ---
POSTGRES_USER=rai
POSTGRES_PASSWORD=change-in-prod
POSTGRES_DB=rai

# --- Identity (IdP) ---
# Connection string injected as ConnectionStrings__Identity
ConnectionStrings__Identity=Host=postgres;Database=rai;Username=rai;Password=change-in-prod

# Fixed issuer embedded in all JWTs — must be the public-facing URL browsers use.
# In docker compose this matches the exposed port on the host machine.
Identity__Issuer=http://localhost:5100

# OIDC client secrets (must match the values seeded in DataSeeder.cs)
Oidc__CrmClientSecret=crm-secret-change-in-prod
Oidc__TicketingClientSecret=ticketing-secret-change-in-prod

# --- Integration Hub ---
ConnectionStrings__Hub=Host=postgres;Database=rai;Username=rai;Password=change-in-prod

# HMAC secret used to verify inbound webhooks from CRM (must equal Crm__HmacSecret)
Hub__InboundHmacSecret=shared-hmac-secret-change-in-prod

# HMAC secret used to sign outbound webhooks to Ticketing (must equal Ticketing__HmacSecret)
Hub__OutboundHmacSecret=shared-hmac-secret-change-in-prod

# Where the hub delivers outbound events (internal docker network URL)
Hub__TicketingWebhookUrl=http://ticketing:5400/api/webhooks/crm-contact-created

# --- CRM Service ---
# OIDC authority — on macOS Docker Desktop host.docker.internal reaches the host,
# which port-forwards to the identity container. SetIssuer in Identity ensures
# the issuer claim always matches http://localhost:5100.
Oidc__Authority=http://host.docker.internal:5100

# HMAC secret for signing webhooks sent to hub (must equal Hub__InboundHmacSecret)
Crm__HmacSecret=shared-hmac-secret-change-in-prod

# Hub webhook receiver URL (internal docker network URL)
Crm__HubWebhookUrl=http://hub:5200/api/webhooks/crm

# --- Ticketing Service ---
# HMAC secret for verifying webhooks from hub (must equal Hub__OutboundHmacSecret)
Ticketing__HmacSecret=shared-hmac-secret-change-in-prod
